    SA --> ENGINE["📍 Motor de alertas de Campo<br/>(distancia empleado↔estación)"]
    ENGINE --> FCM["🔔 FCM push"]
    FCM --> APP["📱 App Flutter<br/>(zumbido + banner)"]

