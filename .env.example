# ══════════════════════════════════════════════════════════════════════
#  Ximbra — variables de entorno
#  Copia este archivo como .env y completa los valores antes de desplegar
#  NUNCA subas .env al repositorio
# ══════════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────────
DJANGO_ENV=production
DJANGO_DEBUG=False
# Genera con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=CAMBIAR-genera-una-clave-segura

ALLOWED_HOSTS=ximbra.creativa2b.net.pe
FRONTEND_URL=https://ximbra.creativa2b.net.pe
CORS_ALLOWED_ORIGINS=https://ximbra.creativa2b.net.pe

# ── Modo uni-tenant ────────────────────────────────────────────────────
SINGLE_TENANT_MODE=True
MAIN_TENANT_SLUG=ximbra

# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_DB=ximbra_db
POSTGRES_USER=ximbra_user
POSTGRES_PASSWORD=CAMBIAR-password-seguro
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_PASSWORD=CAMBIAR-redis-password-seguro
REDIS_URL=redis://:CAMBIAR-redis-password-seguro@redis:6379
CELERY_BROKER_URL=redis://:CAMBIAR-redis-password-seguro@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CAMBIAR-redis-password-seguro@redis:6379/0

# ── MongoDB ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=ximbra_mongo

# ── Admin por defecto (solo primer deploy — cambia inmediatamente) ─────
DEFAULT_ADMIN_EMAIL=admin@ximbra.creativa2b.net.pe
DEFAULT_ADMIN_PASSWORD=CAMBIAR-password-admin-fuerte

# ── Email SMTP ────────────────────────────────────────────────────────
# Resend:   EMAIL_HOST=smtp.resend.com  EMAIL_HOST_USER=resend  EMAIL_HOST_PASSWORD=re_xxxx
# SendGrid: EMAIL_HOST=smtp.sendgrid.net  EMAIL_HOST_USER=apikey  EMAIL_HOST_PASSWORD=SG.xxxx
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=CAMBIAR
EMAIL_HOST_PASSWORD=CAMBIAR
DEFAULT_FROM_EMAIL=noreply@ximbra.creativa2b.net.pe

# ── MinIO (S3 local) ──────────────────────────────────────────────────
MINIO_ROOT_USER=CAMBIAR-minio-user
MINIO_ROOT_PASSWORD=CAMBIAR-minio-password-seguro
MINIO_BUCKET=ximbra
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

AWS_ACCESS_KEY_ID=CAMBIAR-minio-user
AWS_SECRET_ACCESS_KEY=CAMBIAR-minio-password-seguro
AWS_STORAGE_BUCKET_NAME=ximbra
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1

# ── FastAPI auth ──────────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
FASTAPI_SECRET_KEY=CAMBIAR-genera-token-hex-32
FASTAPI_ALGORITHM=HS256

# ── Telegram Bot ──────────────────────────────────────────────────────
# Obtén el token creando un bot con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=CAMBIAR-token-de-botfather
TELEGRAM_NOTIFIER_CYCLE_SEC=300

# ── Ciclos de servicios ───────────────────────────────────────────────
INGESTOR_CYCLE_SEC=3600
PREDICTOR_CYCLE_SEC=3600

# ── Firebase / FCM — alertas push a dispositivos de campo ─────────────
# Descarga el JSON de cuenta de servicio desde Firebase Console
# (Configuración > Cuentas de servicio > Generar nueva clave privada)
# y pégalo aquí como una sola línea (sin saltos de línea)
FIREBASE_CREDENTIALS_JSON=

# ── MQTT Broker — Mosquitto ───────────────────────────────────────────
MQTT_PORT=1883

# ── Puertos (opcional — defaults seguros) ─────────────────────────────
# DJANGO_PORT=8000
# FASTAPI_PORT=8001
# VUE_PORT=3000
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# MONGODB_PORT=27017
